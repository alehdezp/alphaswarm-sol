# AlphaSwarm.sol Agent Docker Image
# Optimized for multi-agent orchestration and non-interactive use
#
# Usage:
#   docker build -f Dockerfile.agent -t alphaswarm-sol:0.5.0-agent .
#   docker run --rm alphaswarm-sol:0.5.0-agent build-kg /workspace
#
# Environment variables for agent mode are pre-configured:
#   ALPHASWARM_AGENT_MODE=1 - Non-interactive behavior
#   ALPHASWARM_OUTPUT_FORMAT=json - Machine-parseable output
#   ALPHASWARM_NO_INTERACTIVE=1 - Disable all prompts

# =============================================================================
# Stage 1: Builder (shared with CLI)
# =============================================================================
FROM python:3.11-slim-bookworm AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency resolution
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Set up working directory
WORKDIR /app

# Copy dependency files first (better layer caching)
COPY pyproject.toml uv.lock README.md ./

# Copy source code (needed for uv sync to install the package)
COPY src/ ./src/
COPY patterns/ ./patterns/
COPY vulndocs/ ./vulndocs/
COPY schemas/ ./schemas/

# Create virtual environment and install dependencies
RUN uv sync --frozen --no-dev \
    && chmod -R a+rX /app

# =============================================================================
# Stage 2: Agent Runtime
# =============================================================================
FROM python:3.11-slim-bookworm AS agent

# OCI Labels
LABEL org.opencontainers.image.title="AlphaSwarm.sol Agent"
LABEL org.opencontainers.image.description="Agent-optimized AlphaSwarm.sol for multi-agent orchestration"
LABEL org.opencontainers.image.version="0.5.0-agent"
LABEL org.opencontainers.image.source="https://github.com/alphaswarm/alphaswarm-sol"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.vendor="AlphaSwarm"

# Install runtime dependencies and solc-select in single layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir solc-select \
    && solc-select install 0.8.20 \
    && solc-select use 0.8.20

# Create non-root user for security
RUN useradd --create-home --shell /bin/bash alphaswarm \
    && mkdir -p /workspace \
    && chown -R alphaswarm:alphaswarm /workspace

# Copy virtual environment from builder (already has correct permissions)
COPY --from=builder /app/.venv /app/.venv

# Copy application code and data
WORKDIR /app
COPY --from=builder /app/src ./src
COPY --from=builder /app/patterns ./patterns
COPY --from=builder /app/vulndocs ./vulndocs
COPY --from=builder /app/schemas ./schemas
COPY --from=builder /app/pyproject.toml ./

# Set up PATH to use virtual environment
ENV PATH="/app/.venv/bin:$PATH"
ENV VIRTUAL_ENV="/app/.venv"

# =============================================================================
# Agent Mode Environment Variables
# =============================================================================
# Enable agent mode for non-interactive behavior
ENV ALPHASWARM_AGENT_MODE=1

# Output format optimized for machine parsing
ENV ALPHASWARM_OUTPUT_FORMAT=json

# Disable all interactive prompts
ENV ALPHASWARM_NO_INTERACTIVE=1

# Structured logging for agent parsing
ENV ALPHASWARM_LOG_FORMAT=json

# Disable colors in output (cleaner for parsing)
ENV NO_COLOR=1
ENV FORCE_COLOR=0

USER alphaswarm

# Set working directory for analysis
WORKDIR /workspace

# Expose volume for contracts and output
VOLUME ["/workspace"]

# Entry point to AlphaSwarm CLI in agent mode
ENTRYPOINT ["alphaswarm"]
CMD ["--help"]

# =============================================================================
# Health check for orchestration systems
# =============================================================================
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD alphaswarm --version || exit 1
