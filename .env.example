# True VKG - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM PROVIDERS (P0-T0 LLM Abstraction)
# =============================================================================
# At least one LLM provider is required. Priority order is configurable.
# The system will automatically fall back to the next available provider.

# Google Gemini (Recommended: cheapest, fastest for bulk work)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude (Quality fallback)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT (Second fallback)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI Grok (Code-focused alternative)
# Get key: https://console.x.ai/
XAI_API_KEY=

# DeepSeek (Cost-effective alternative)
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# =============================================================================
# RESEARCH TOOLS
# =============================================================================

# Exa Search (for vulnerability research)
# Get key: https://exa.ai/
EXA_API_KEY=

# =============================================================================
# SECURITY SCANNING TOOLS (Optional)
# =============================================================================

# Snyk (dependency scanning)
SNYK_TOKEN=

# Semgrep (static analysis)
SEMGREP_APP_TOKEN=

# =============================================================================
# LLM CONFIGURATION (Optional overrides)
# =============================================================================

# Maximum budget per session in USD (empty = unlimited)
# LLM_MAX_BUDGET_USD=10.0

# Enable/disable response caching (default: true)
# LLM_CACHE_ENABLED=true

# Default model preferences (uncomment to override)
# LLM_ANTHROPIC_MODEL=claude-3-5-haiku-latest
# LLM_GOOGLE_MODEL=gemini-2.0-flash
# LLM_OPENAI_MODEL=gpt-4o-mini
# LLM_XAI_MODEL=grok-2

# Provider priority (comma-separated, first = highest priority)
# LLM_PROVIDER_PRIORITY=google,anthropic,openai,xai,ollama
