{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaswarm.sol/schemas/phase_plan_contract.schema.json",
  "title": "Phase Plan Derived Checks Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phase_id",
    "plan_id",
    "generated_at",
    "source_context",
    "preconditions",
    "investigation_checks",
    "research_tasks",
    "hitl_runbook",
    "hardcoding_guard"
  ],
  "properties": {
    "phase_id": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+)?[a-z]?$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+)?[a-z]?-[0-9]{2}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_context": {
      "type": "string",
      "minLength": 1
    },
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "evidence_sources",
          "risk_if_unresolved"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^P[0-9]{2}$"
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "evidence_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "risk_if_unresolved": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "investigation_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "question",
          "check_type",
          "requires_research",
          "evidence_sources",
          "baseline_derivation",
          "success_rule",
          "anti_hardcode_assertion"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^CHK-[0-9]{2}$"
          },
          "question": {
            "type": "string",
            "minLength": 5
          },
          "check_type": {
            "type": "string",
            "enum": [
              "invariant",
              "delta",
              "ratio",
              "coverage",
              "artifact_presence",
              "human_decision"
            ]
          },
          "requires_research": {
            "type": "boolean"
          },
          "evidence_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "source",
                "why"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "command",
                    "file",
                    "report",
                    "external_ref",
                    "human_observation"
                  ]
                },
                "source": {
                  "type": "string",
                  "minLength": 3
                },
                "why": {
                  "type": "string",
                  "minLength": 3
                }
              }
            }
          },
          "baseline_derivation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "strategy",
              "source_ref",
              "derivation_steps"
            ],
            "properties": {
              "strategy": {
                "type": "string",
                "enum": [
                  "measure_current",
                  "compare_previous_phase",
                  "external_reference",
                  "human_review"
                ]
              },
              "source_ref": {
                "type": "string",
                "minLength": 3
              },
              "derivation_steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 3
                }
              }
            }
          },
          "success_rule": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rule_type",
              "expression",
              "variables"
            ],
            "properties": {
              "rule_type": {
                "type": "string",
                "enum": [
                  "invariant",
                  "delta",
                  "ratio",
                  "coverage",
                  "human_decision"
                ]
              },
              "expression": {
                "type": "string",
                "minLength": 5
              },
              "variables": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "anti_hardcode_assertion": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "research_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "question",
          "method",
          "output_ref"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R[0-9]{2}$"
          },
          "question": {
            "type": "string",
            "minLength": 5
          },
          "method": {
            "type": "string",
            "minLength": 3
          },
          "output_ref": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "hitl_runbook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "runbook_path",
        "time_budget_minutes"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "minLength": 3
        },
        "runbook_path": {
          "type": "string",
          "minLength": 3
        },
        "time_budget_minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "hardcoding_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_derived_thresholds",
        "disallow_static_pass_fail",
        "explanation"
      ],
      "properties": {
        "requires_derived_thresholds": {
          "const": true
        },
        "disallow_static_pass_fail": {
          "const": true
        },
        "explanation": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
