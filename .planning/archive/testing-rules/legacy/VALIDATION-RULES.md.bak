## AUTOMATED ENFORCEMENT

### Pre-Merge Check

```bash
#!/bin/bash
# .git/hooks/pre-merge or CI check

set -e

echo "=== VALIDATION RULES CHECK ==="

# A1: No mock mode in validation
if grep -r "mode.*mock\|mode.*simulated" scripts/run_*.py 2>/dev/null; then
    echo "FAIL: Mock mode detected in validation scripts"
    exit 1
fi
echo "✓ A1: No mock mode"

# A2: No hardcoded tokens
if grep -r "tokens_used.*+=" scripts/run_*.py 2>/dev/null; then
    echo "FAIL: Hardcoded token counts detected"
    exit 1
fi
echo "✓ A2: No hardcoded tokens"

# B1: No fabricated ground truth
if grep -r "is_true_positive.*=" scripts/run_*.py 2>/dev/null; then
    echo "FAIL: Hardcoded ground truth labels detected"
    exit 1
fi
echo "✓ B1: No fabricated ground truth"

# C1: Check for zero duration
for report in .vrs/testing/reports/*.json; do
    if [ -f "$report" ]; then
        if jq -e '.duration_ms == 0' "$report" > /dev/null 2>&1; then
            echo "FAIL: Zero duration in $report"
            exit 1
        fi
    fi
done
echo "✓ C1: Non-zero durations"

# F1: Transcript length verification
for transcript in .vrs/testing/runs/*/transcript.txt; do
    if [ -f "$transcript" ]; then
        lines=$(wc -l < "$transcript")
        if [ "$lines" -lt 50 ]; then
            echo "FAIL: F1 - Transcript too short ($lines lines): $transcript"
            exit 1
        fi
    fi
done
echo "✓ F1: Transcript lengths valid"

# F2: Tool invocation markers
for transcript in .vrs/testing/runs/*/transcript.txt; do
    if [ -f "$transcript" ]; then
        if ! grep -qE "alphaswarm|slither|Attacker:|Defender:|Verifier:" "$transcript"; then
            echo "FAIL: F2 - No tool invocations in: $transcript"
            exit 1
        fi
    fi
done
echo "✓ F2: Tool invocations present"

# F3: Duration thresholds by operation type
for report in .vrs/testing/reports/*.json; do
    if [ -f "$report" ]; then
        operation=$(jq -r '.operation // "unknown"' "$report")
        duration=$(jq -r '.duration_ms // 0' "$report")
        case "$operation" in
            e2e_audit)
                if [ "$duration" -lt 120000 ]; then
                    echo "FAIL: F3 - E2E audit too fast (${duration}ms < 120000ms): $report"
                    exit 1
                fi
                ;;
            agent_unit)
                if [ "$duration" -lt 30000 ]; then
                    echo "FAIL: F3 - Agent unit test too fast (${duration}ms < 30000ms): $report"
                    exit 1
                fi
                ;;
        esac
    fi
done
echo "✓ F3: Duration thresholds met"

# G2: Dependency verification for GA report
if [ -f ".vrs/testing/reports/ga-readiness.json" ]; then
    for dep in ".vrs/testing/reports/e2e-audit.json" ".vrs/testing/reports/solo-vs-swarm.json" ".vrs/testing/reports/blind-validation.json"; do
        if [ ! -f "$dep" ]; then
            echo "FAIL: G2 - Missing dependency for GA report: $dep"
            exit 1
        fi
    done
    echo "✓ G2: GA report dependencies exist"
fi

echo ""
echo "=== ALL VALIDATION RULES PASSED ==="
```

### Report Validation Script

```python
#!/usr/bin/env python3
"""scripts/validate_report_integrity.py"""

import json
import re
import sys
from pathlib import Path

# F3: Minimum duration thresholds by operation type
MIN_DURATIONS = {
    'smoke_test': 5000,      # 5 seconds minimum
    'agent_unit': 30000,     # 30 seconds minimum
    'integration': 60000,    # 1 minute minimum
    'e2e_audit': 120000,     # 2 minutes minimum
    'full_audit': 180000,    # 3 minutes minimum
}

# F2: Required tool invocation markers
REQUIRED_MARKERS = [
    r"alphaswarm\s+build-kg",
    r"Knowledge graph.*built",
    r"Attacker:|Defender:|Verifier:",
    r"\.sol\s*$|contracts/\w+\.sol",
]


def validate_report(path: Path) -> list[str]:
    """Validate a report against integrity rules."""
    errors = []

    with open(path) as f:
        report = json.load(f)

    # Rule A3: Non-zero duration
    if report.get("duration_ms", 0) < 1000:
        errors.append(f"A3 VIOLATION: duration_ms={report.get('duration_ms')} < 1000")

    # Rule C1: Suspicious perfect metrics
    precision = report.get("precision", 0)
    recall = report.get("recall", 0)
    if precision >= 0.95 and recall >= 0.98:
        errors.append(f"C1 WARNING: Suspiciously perfect metrics (P={precision}, R={recall})")

    # Rule E1: Mode declaration
    mode = report.get("mode") or report.get("metadata", {}).get("mode")
    if mode in ["mock", "simulated"]:
        errors.append(f"E1 VIOLATION: Report uses {mode} mode, not 'live'")

    # Rule E2: Limitations required
    if not report.get("limitations"):
        errors.append("E2 VIOLATION: No limitations section")

    # Rule F3: Duration threshold by operation type
    operation = report.get("operation", "unknown")
    duration = report.get("duration_ms", 0)
    min_duration = MIN_DURATIONS.get(operation, 5000)
    if duration < min_duration:
        errors.append(f"F3 VIOLATION: {operation} duration {duration}ms < {min_duration}ms minimum")

    # Rule F4: Cross-evidence verification for findings
    for i, finding in enumerate(report.get("findings", [])):
        finding_id = finding.get("id", f"finding-{i}")
        if not finding.get("graph_nodes"):
            errors.append(f"F4 VIOLATION: {finding_id} has no graph_nodes")
        if not finding.get("pattern_id"):
            errors.append(f"F4 VIOLATION: {finding_id} has no pattern_id")
        location = finding.get("location", "")
        if not location or ":" not in location:
            errors.append(f"F4 VIOLATION: {finding_id} has no valid location (file:line)")

    return errors


def validate_transcript(path: Path) -> list[str]:
    """Validate a transcript against anti-fabrication rules."""
    errors = []
    content = path.read_text()
    lines = content.strip().split('\n')

    # Rule F1: Transcript length
    if len(lines) < 50:
        errors.append(f"F1 VIOLATION: Transcript has {len(lines)} lines (< 50 minimum)")

    # Rule F1: Claude prompt markers
    if not any('>>>' in line for line in lines):
        errors.append("F1 VIOLATION: No Claude prompt markers (>>>) found")

    # Rule F2: Tool invocation markers
    marker_matches = sum(1 for pattern in REQUIRED_MARKERS if re.search(pattern, content, re.IGNORECASE))
    if marker_matches < 2:
        errors.append(f"F2 VIOLATION: Only {marker_matches}/4 tool markers found (need >= 2)")

    return errors


if __name__ == "__main__":
    all_errors = []

    # Validate reports
    reports_dir = Path(".vrs/testing/reports")
    if reports_dir.exists():
        for path in reports_dir.glob("*.json"):
            errors = validate_report(path)
            if errors:
                all_errors.extend([f"{path.name}: {e}" for e in errors])

    # Validate transcripts
    transcripts_dir = Path(".vrs/testing/runs")
    if transcripts_dir.exists():
        for path in transcripts_dir.glob("*.txt"):
            errors = validate_transcript(path)
            if errors:
                all_errors.extend([f"{path.name}: {e}" for e in errors])

    if all_errors:
        print("VALIDATION FAILURES:")
        for e in all_errors:
            print(f"  - {e}")
        sys.exit(1)
    else:
        print("All reports and transcripts pass validation")
```

---

## PHASE COMPLETION CHECKLIST

Before marking ANY validation phase complete:

### Execution Checks
- [ ] All tests use LIVE mode (not mock/simulated)
- [ ] Durations are non-zero and realistic
- [ ] Token usage is measured from API (not hardcoded)
- [ ] Agent Teams-based execution used for interactive tests

### Ground Truth Checks
- [ ] Ground truth comes from external source
- [ ] Provenance documented for all labels
- [ ] No `is_true_positive=True/False` in code

### Metrics Checks
- [ ] Metrics show variance across test cases
- [ ] No suspiciously perfect results (100%/0%)
- [ ] Error budget documented and realistic

### Infrastructure Checks
- [ ] `/vrs-test-workflow` used for workflow validation
- [ ] Transcripts captured and stored
- [ ] Test subject isolated from controller

### Reporting Checks
- [ ] Mode declared as "live"
- [ ] Limitations documented honestly
- [ ] No hidden mock acknowledgments

### Anti-Fabrication Checks (Category F)
- [ ] Transcripts have minimum line count (50+ for smoke, 200+ for E2E)
- [ ] Transcripts contain tool invocation markers
- [ ] Duration matches operation type thresholds
- [ ] Findings have cross-evidence (graph nodes, pattern ID, location)

### Artifact Dependency Checks (Category G)
- [ ] Plan declares produced artifacts
- [ ] Dependencies verified before execution
- [ ] Wave gate conditions met before proceeding

