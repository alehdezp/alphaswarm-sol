        WorkflowEvaluator,
        ImprovementLoop,
        EvalStatus,
        EvalCriteria,
        EvalResult,
        Improvement,
    )

    # Evaluate result
    criteria = EvalCriteria(expected_patterns=["PASS", "Complete"])
    evaluator = WorkflowEvaluator()
    eval_result = evaluator.evaluate(transcript, criteria)

    # Process improvements
    loop = ImprovementLoop()
