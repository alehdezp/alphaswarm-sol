# AlphaSwarm.sol Docker Ignore
# Exclude files not needed in Docker builds

# =============================================================================
# Git and Version Control
# =============================================================================
.git
.gitignore
.jj

# =============================================================================
# Development and IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Python Build Artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environments
# =============================================================================
.venv/
venv/
ENV/
env/

# =============================================================================
# Testing
# =============================================================================
tests/
.pytest_cache/
.testmondata
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# Type Checking and Linting
# =============================================================================
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Documentation and Planning
# =============================================================================
docs/
.planning/
*.md
!README.md

# =============================================================================
# CI/CD and GitHub
# =============================================================================
.github/

# =============================================================================
# Local Configuration and Secrets
# =============================================================================
.env
.env.*
*.env
!.env.example

# =============================================================================
# Generated Data and Caches
# =============================================================================
graphs/
.data/
.cache/
neo4j-data/
chroma-data/
**/.true_vkg/
**/.vrs/
**/graph.json
**/*.kg.json

# =============================================================================
# Examples and Benchmarks (not needed in production image)
# =============================================================================
examples/
benchmarks/
validation/
knowledge/

# =============================================================================
# Temporary Files
# =============================================================================
temp/
tmp/
*.tmp
*.temp
*.log

# =============================================================================
# Editor and OS Files
# =============================================================================
.DS_Store
Thumbs.db
*.bak

# =============================================================================
# Docker Files (avoid recursive copying)
# =============================================================================
docker-compose*.yml
Dockerfile*
!Dockerfile
